# Display + backlight config for the open kernel: the LCD backlight (PWM) and the
# DRM/KMS path (VO display controller + dw-mipi-dsi + panel).
#
# MERGE AFTER trim.config. Mainline pieces are built-in (=y), matching the rest of the
# baked-in config; the out-of-tree artosyn_pwm.ko provides the actual PWM chip.

# PWM core + pwm-backlight (the artosyn,ar9301-pwm provider is the out-of-tree module).
CONFIG_PWM=y
CONFIG_BACKLIGHT_CLASS_DEVICE=y
CONFIG_BACKLIGHT_PWM=y

# DRM/KMS image path
# CONFIG_DRM_ARTOSYN (patches/drivers/gpu/drm/artosyn) is built as a MODULE. It
# selects the select-only DRM helpers (KMS_HELPER/GEM_DMA_HELPER/MIPI_DSI/DW_MIPI_DSI/
# PANEL/FBDEV_DMA/CLIENT_SELECTION); because nothing built-in selects them, =m on DRM_ARTOSYN
# pulls the entire DRM stack (core + helpers + dw-mipi-dsi) in as modules too. That keeps the
# DRM mass out of the Image (LZ4/Falcon 6MB budget). Requires `make modules` + the .ko loaded
# from the rootfs (load order in load.sh). CMA is built-in (=y) - it backs the contiguous
# scanout framebuffers and reserves at boot.
CONFIG_DRM=m
CONFIG_DRM_FBDEV_EMULATION=y
CONFIG_DRM_ARTOSYN=m
CONFIG_CMA=y
CONFIG_DMA_CMA=y
# 16 MiB covers scanout alone; codec.config (merged later) overrides this to 56 MiB
# for the wave5 decoder's framebuffers.
CONFIG_CMA_SIZE_MBYTES=16

# DMA-BUF CMA heap (/dev/dma_heap/*): userspace allocator for contiguous dma-bufs.
# A heap-allocated buffer can be PRIME-imported into the VO primary plane, so userspace
# can hand contiguous buffers (e.g. decoder output) to scanout without a kernel-side
# allocator.
CONFIG_DMABUF_HEAPS=y
CONFIG_DMABUF_HEAPS_CMA=y

# Disable the other-vendor DRM drivers that `DRM` drags in. None apply to this SoC
# (its display is DRM_ARTOSYN: VO + dw-mipi-dsi + QY45043A0). This avoids building their .ko
# and removes their helper-lib (SCHED/GPUVM/SHMEM) pulls. DRM_ARTOSYN keeps
# KMS_HELPER/GEM_DMA_HELPER/MIPI_DSI/DW_MIPI_DSI/PANEL/CLIENT (=m, via select).
# CONFIG_DRM_ETNAVIV is not set
# CONFIG_DRM_LIMA is not set
# CONFIG_DRM_PANFROST is not set
# CONFIG_DRM_PANTHOR is not set
# CONFIG_DRM_POWERVR is not set
# CONFIG_DRM_HDLCD is not set
# CONFIG_DRM_MALI_DISPLAY is not set
# CONFIG_DRM_KOMEDA is not set
# CONFIG_DRM_HISI_KIRIN is not set
# CONFIG_DRM_TIDSS is not set
# CONFIG_DRM_NWL_MIPI_DSI is not set
# CONFIG_DRM_SAMSUNG_DSIM is not set
# CONFIG_DRM_CDNS_DSI is not set
# CONFIG_DRM_PANEL_EDP is not set
# CONFIG_DRM_PANEL_LVDS is not set
# CONFIG_DRM_PANEL_SIMPLE is not set
# CONFIG_DRM_SIMPLE_BRIDGE is not set
# CONFIG_DRM_AUX_BRIDGE is not set
# CONFIG_DRM_AUX_HPD_BRIDGE is not set
# CONFIG_DRM_DISPLAY_CONNECTOR is not set
# CONFIG_DRM_DISPLAY_DP_AUX_BUS is not set
