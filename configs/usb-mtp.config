# MTP-over-USB for the DVR recordings gadget (this repo's issue #5).
#
# MTP on a configfs gadget is FunctionFS (f_fs) + a userspace responder
# (uMTP-Responder / umtprd, built in the wrapper's native/umtprd/). The responder
# writes the MTP descriptors to ffs ep0; the kernel only needs the FunctionFS
# gadget function enabled here.
#
# Merged AFTER trim.config, which explicitly disables both this and mass_storage
# (trim.config: `# CONFIG_USB_CONFIGFS_F_FS is not set`). artosyn.config is merged
# BEFORE trim, so an enable there is clobbered - this post-trim fragment is the one
# that actually wins. See scripts/container-build.sh (frags order: artosyn.config,
# then trim.config, then these post-trim fragments).
#
# f_fs is small; it adds no measurable weight to the trimmed kernel. Mass-storage
# (CONFIG_USB_CONFIGFS_MASS_STORAGE) stays OFF: it is the documented fallback, not
# the shipped path (block-exclusive, cannot coexist with an actively-recording SD
# card).
CONFIG_USB_CONFIGFS_F_FS=y

# umtprd's internal control queue uses a POSIX message queue (mq_open("/umtprd")).
# POSIX_MQUEUE is `default y` upstream, but trim.config strips aggressively and this is
# a hard umtprd dependency, so pin it explicitly. No /dev/mqueue mount is needed (mq_open
# uses the kernel mqueue namespace directly).
CONFIG_POSIX_MQUEUE=y
