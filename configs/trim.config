# Disable hardware/subsystems this device lacks, shrinking the Image (~48 MiB generic
# arm64 defconfig) toward the vendor's ~10 MiB so the OTRA container fits the 6 MiB
# kernelN partition (LZ4-compressed) for a persistent slot flash.
#
# Merged AFTER artosyn.config and BEFORE the add-back fragments (modules, input, spi,
# display, codec, exfat). Anything this device actually uses (8250/mmc/dwc2/wdt/i2c/spi/gpio,
# UBI/squashfs, the configfs ECM gadget, FUSE/CUSE, binder, the MMZ carveout, plus what the
# add-backs re-assert: FB/MMC/IKCONFIG, DRM, V4L2, IIO/input, DW SPI, exFAT) survives the
# disables here. Approximate text savings are noted where they drove a cut.

# other-SoC platform families (DT-only generic build; each would pull in that SoC's
#     pinctrl/clk/regulator/soc drivers)
# CONFIG_ARCH_ACTIONS is not set
# CONFIG_ARCH_AIROHA is not set
# CONFIG_ARCH_SUNXI is not set
# CONFIG_ARCH_ALPINE is not set
# CONFIG_ARCH_APPLE is not set
# CONFIG_ARCH_ARTPEC is not set
# CONFIG_ARCH_AXIADO is not set
# CONFIG_ARCH_BCM is not set
# CONFIG_ARCH_BCM2835 is not set
# CONFIG_ARCH_BCM_IPROC is not set
# CONFIG_ARCH_BCMBCA is not set
# CONFIG_ARCH_BRCMSTB is not set
# CONFIG_ARCH_BERLIN is not set
# CONFIG_ARCH_BLAIZE is not set
# CONFIG_ARCH_CIX is not set
# CONFIG_ARCH_EXYNOS is not set
# CONFIG_ARCH_K3 is not set
# CONFIG_ARCH_LG1K is not set
# CONFIG_ARCH_HISI is not set
# CONFIG_ARCH_KEEMBAY is not set
# CONFIG_ARCH_MEDIATEK is not set
# CONFIG_ARCH_MESON is not set
# CONFIG_ARCH_MICROCHIP is not set
# CONFIG_ARCH_SPARX5 is not set
# CONFIG_ARCH_MVEBU is not set
# CONFIG_ARCH_NXP is not set
# CONFIG_ARCH_LAYERSCAPE is not set
# CONFIG_ARCH_MXC is not set
# CONFIG_ARCH_S32 is not set
# CONFIG_ARCH_MA35 is not set
# CONFIG_ARCH_NPCM is not set
# CONFIG_ARCH_QCOM is not set
# CONFIG_ARCH_REALTEK is not set
# CONFIG_ARCH_RENESAS is not set
# CONFIG_ARCH_ROCKCHIP is not set
# CONFIG_ARCH_SEATTLE is not set
# CONFIG_ARCH_INTEL_SOCFPGA is not set
# CONFIG_ARCH_STM32 is not set
# CONFIG_ARCH_SYNQUACER is not set
# CONFIG_ARCH_TEGRA is not set
# CONFIG_ARCH_TESLA_FSD is not set
# CONFIG_ARCH_SOPHGO is not set
# CONFIG_ARCH_SPRD is not set
# CONFIG_ARCH_THUNDER is not set
# CONFIG_ARCH_THUNDER2 is not set
# CONFIG_ARCH_UNIPHIER is not set
# CONFIG_ARCH_VEXPRESS is not set
# CONFIG_ARCH_VISCONTI is not set
# CONFIG_ARCH_XGENE is not set
# CONFIG_ARCH_ZYNQMP is not set
# CONFIG_ARCH_BITMAIN is not set

# display / graphics (FB is re-enabled by modules.config for the DRM fbdev console;
#     DRM + backlight are re-enabled by display.config)
# CONFIG_DRM is not set
# CONFIG_FB is not set
# CONFIG_BACKLIGHT_CLASS_DEVICE is not set
# CONFIG_LOGO is not set

# SD / eMMC (not needed for bring-up or the NAND-rooted persistent boot; ~350 KB.
#     Re-enabled by artosyn.config + modules.config for the SD card / artosyn_sdio)
# CONFIG_MMC is not set

# audio (handled by the vendor stack, not ALSA)
# CONFIG_SOUND is not set

# V4L / media (re-enabled by codec.config, which needs only the V4L2 mem2mem core
#     for the wave5 codec, not the defconfig's full media/camera/tuner sprawl)
# CONFIG_MEDIA_SUPPORT is not set

# buses / storage classes this device does not have
# CONFIG_PCI is not set
# CONFIG_NVME_CORE is not set
# CONFIG_SCSI is not set
# CONFIG_ATA is not set
# CONFIG_MD is not set
# CONFIG_FUSION is not set
# CONFIG_FIREWIRE is not set
# CONFIG_THUNDERBOLT is not set
# CONFIG_MEMSTICK is not set

# radios this device does not have (RF is the ar8030 link via the vendor stack)
# CONFIG_WLAN is not set
# CONFIG_WIRELESS is not set
# CONFIG_BT is not set
# CONFIG_RFKILL is not set
# CONFIG_NFC is not set
# CONFIG_CAN is not set
# CONFIG_WWAN is not set

# misc subsystems not needed for bring-up (IIO is re-enabled by input.config for the
#     SAR-ADC front-panel buttons)
# CONFIG_INFINIBAND is not set
# CONFIG_IIO is not set
# CONFIG_HWMON is not set
# CONFIG_THERMAL is not set
# CONFIG_MACINTOSH_DRIVERS is not set
# CONFIG_USB_NET_DRIVERS is not set

# input (~160 KB; KEYBOARD + EVDEV are re-enabled by input.config for the front-panel
#     buttons, the rest stays off)
# CONFIG_INPUT_TOUCHSCREEN is not set
# CONFIG_INPUT_JOYSTICK is not set
# CONFIG_INPUT_TABLET is not set
# CONFIG_INPUT_KEYBOARD is not set
# CONFIG_INPUT_MOUSE is not set
# CONFIG_INPUT_MOUSEDEV is not set
# CONFIG_INPUT_EVDEV is not set
# CONFIG_INPUT_JOYDEV is not set
# CONFIG_INPUT_MISC is not set

# CPU / boot
# 2 Cortex-A53 cores, not 256: shrinks cpumask/per-CPU static arrays kernel-wide
# (cpu_topology ~136 KB, cpu_madt_gicc ~42 KB)
CONFIG_NR_CPUS=4
# DT-only boot; no ACPI/UEFI ("efi: UEFI not found" in the boot log)
# CONFIG_ACPI is not set
# CONFIG_EFI is not set
# single SoC, single memory node
# CONFIG_NUMA is not set

# kernel features this device does not use
# full symbol table (~1 MiB); basic kallsyms for oops stays
# CONFIG_KALLSYMS_ALL is not set
# CONFIG_BPF_SYSCALL is not set
# CONFIG_HID_SUPPORT is not set
# CONFIG_MAGIC_SYSRQ is not set
# CONFIG_PROFILING is not set
# CONFIG_AUDIT is not set
# CONFIG_KSM is not set
# CONFIG_VIRTUALIZATION is not set
# CONFIG_XEN is not set
# embedded /proc/config.gz (re-enabled by mpp-modules.config) + crypto self-test vectors
# CONFIG_IKCONFIG is not set
CONFIG_CRYPTO_MANAGER_DISABLE_TESTS=y
# printk: 16 KB log buffer. The static ringbuffer infos/descs scale with this shift
# (_printk_rb_static_infos ~176 KB, descs ~48 KB). Serial captures the full boot/oops log regardless.
CONFIG_LOG_BUF_SHIFT=14

# compile for size
# -Os instead of -O2, plus linker garbage-collection of unreferenced code/data (no feature lost)
CONFIG_CC_OPTIMIZE_FOR_SIZE=y
CONFIG_LD_DEAD_CODE_DATA_ELIMINATION=y
# vmlinux debug info only (the Image is objcopy-stripped regardless); speeds builds
CONFIG_DEBUG_INFO_NONE=y

# networking (keep core IPv4 + TCP for the ECM gadget / SSH; drop the rest)
# CONFIG_NETFILTER is not set
# CONFIG_IPV6 is not set
# CONFIG_NET_SCHED is not set
# CONFIG_NET_DEVLINK is not set
# CONFIG_INET_DIAG is not set
# CONFIG_IP_MULTICAST is not set
# no real NIC; networking is the USB ECM gadget (~700 KB)
# CONFIG_ETHERNET is not set
# no MDIO NIC, so no PHY drivers (aqr/ksphy/realtek)
# CONFIG_PHYLIB is not set
# CONFIG_MDIO_DEVICE is not set

# filesystems (rootfs is squashfs + ubifs; the SD-card filesystem is in-kernel exFAT
#     from exfat.config, so FAT/VFAT is unused)
# NFS/CIFS/CEPH/9P + sunrpc (~730 KB)
# CONFIG_NETWORK_FILESYSTEMS is not set
# CONFIG_EXT4_FS is not set
# CONFIG_VFAT_FS is not set
# CONFIG_FAT_FS is not set

# drop the ZSTD library (~300 KB): disable every puller so ZSTD_COMPRESS/DECOMPRESS fall
#     out. squashfs keeps xz/lz4 (enough to mount a stock image), ubifs keeps zlib/lzo (our
#     rootfs is mkfs.ubifs -x none, uncompressed, so no decompressor is even invoked), no
#     zstd-compressed initrd, no crypto-zstd consumer.
#     NOTE: UBIFS_FS_ZSTD is `default y` and only user-settable under UBIFS_FS_ADVANCED_COMPR,
#     so enable that to expose the per-codec choice; otherwise the disable is ignored and it
#     force-selects CRYPTO_ZSTD, keeping the whole lib.
# CONFIG_SQUASHFS_ZSTD is not set
CONFIG_UBIFS_FS_ADVANCED_COMPR=y
# CONFIG_UBIFS_FS_ZSTD is not set
# CONFIG_CRYPTO_ZSTD is not set
# CONFIG_RD_ZSTD is not set

# dead-weight subsystems: enabled by arm64 defconfig but never used on this device (each
#     was seen probing in the boot log). Disabling the top-level symbol cascades its children.
# CONFIG_NET_9P is not set
# CONFIG_VFIO is not set
# CONFIG_FPGA is not set
# CONFIG_ARM_SCMI_PROTOCOL is not set
# CONFIG_EDAC is not set
# CONFIG_PTP_1588_CLOCK is not set
# CONFIG_PPS is not set
# CONFIG_TUN is not set
# CONFIG_HUGETLBFS is not set
# CONFIG_QUOTA is not set
# CONFIG_DNS_RESOLVER is not set
# CONFIG_IOSCHED_BFQ is not set
# SD/SDIO here is DesignWare (MMC_DW); the SDHCI controller DT node is disabled, so the whole
# SDHCI driver family is dead weight.
# CONFIG_MMC_SDHCI is not set

# regulators: none in our DT. The core is hard-selected by MMC/USB so the subsystem can't
#     be turned off, but the board-PMIC drivers are standalone defconfig =y and ~130 KB of dead
#     tables for PMICs not on our DT; disable them individually.
# CONFIG_REGULATOR_ARM_SCMI is not set
# CONFIG_REGULATOR_AXP20X is not set
# CONFIG_REGULATOR_BD718XX is not set
# CONFIG_REGULATOR_BD9571MWV is not set
# CONFIG_REGULATOR_CROS_EC is not set
# CONFIG_REGULATOR_FAN53555 is not set
# CONFIG_REGULATOR_HI6421V530 is not set
# CONFIG_REGULATOR_MAX77620 is not set
# CONFIG_REGULATOR_MP8859 is not set
# CONFIG_REGULATOR_MT6357 is not set
# CONFIG_REGULATOR_MT6358 is not set
# CONFIG_REGULATOR_MT6359 is not set
# CONFIG_REGULATOR_MT6360 is not set
# CONFIG_REGULATOR_MT6397 is not set
# CONFIG_REGULATOR_PCA9450 is not set
# CONFIG_REGULATOR_PF8X00 is not set
# CONFIG_REGULATOR_PFUZE100 is not set
# CONFIG_REGULATOR_QCOM_SPMI is not set
# CONFIG_REGULATOR_RAA215300 is not set
# CONFIG_REGULATOR_RK808 is not set
# CONFIG_REGULATOR_ROHM is not set
# CONFIG_REGULATOR_S2MPS11 is not set
# CONFIG_REGULATOR_TPS65219 is not set

# USB: device/gadget only (dwc2 peripheral -> configfs ECM/ACM). Keep USB core + gadget
#     + dwc2; drop host controllers (never a USB host) and the unused gadget functions.
# CONFIG_USB_XHCI_HCD is not set
# CONFIG_USB_EHCI_HCD is not set
# CONFIG_USB_OHCI_HCD is not set
# CONFIG_USB_DWC3 is not set
# CONFIG_USB_MUSB_HDRC is not set
# CONFIG_USB_CHIPIDEA is not set
# CONFIG_USB_CDNS_SUPPORT is not set
# CONFIG_USB_CDNS3 is not set
# CONFIG_USB_OTG is not set
# CONFIG_USB_CONN_GPIO is not set
# gadget functions we don't use (keep ECM + ACM)
# CONFIG_USB_CONFIGFS_RNDIS is not set
# CONFIG_USB_CONFIGFS_MASS_STORAGE is not set
# CONFIG_USB_CONFIGFS_F_FS is not set
# CONFIG_USB_CONFIGFS_F_UAC1 is not set
# CONFIG_USB_CONFIGFS_F_UAC2 is not set
# CONFIG_USB_CONFIGFS_F_MIDI is not set
# CONFIG_USB_CONFIGFS_F_HID is not set
# CONFIG_USB_CONFIGFS_F_PRINTER is not set

# cgroups / namespaces (this device's init uses none). The controllers keep CONFIG_CGROUPS
#     alive against a top-level disable (MEMCG alone ~200 KB), so cut the controllers directly.
# CONFIG_MEMCG is not set
# CONFIG_BLK_CGROUP is not set
# CONFIG_CGROUP_SCHED is not set
# CONFIG_SCHED_AUTOGROUP is not set
# CONFIG_CGROUP_PIDS is not set
# CONFIG_CGROUP_DEVICE is not set
# CONFIG_CGROUP_FREEZER is not set
# CONFIG_CGROUP_CPUACCT is not set
# CONFIG_CGROUP_PERF is not set
# CONFIG_CGROUP_BPF is not set
# CONFIG_CGROUPS is not set
# CONFIG_USER_NS is not set
# CONFIG_NET_NS is not set
# CONFIG_PID_NS is not set
# CONFIG_IPC_NS is not set
# CONFIG_UTS_NS is not set
# CONFIG_TIME_NS is not set
# CONFIG_NAMESPACES is not set
