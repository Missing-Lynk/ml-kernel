# DMA-BUF heaps core. ml_mmzheap registers the "mmz" dma-heap (/dev/dma_heap/mmz) - the pool the
# wave5 encoder allocates from - via dma_heap_add(), which needs CONFIG_DMABUF_HEAPS built in.
# trim.config disables it; the goggle re-enables it as part of display.config (the RX compositor
# also uses dma-heaps), but the air unit has no display, so it lists this fragment to get the heaps
# core its encoder pool depends on. CONFIG_DMA_SHARED_BUFFER is already =y in the base.
#
# MERGE THIS AFTER trim.config.

CONFIG_DMABUF_HEAPS=y
CONFIG_DMABUF_HEAPS_CMA=y
