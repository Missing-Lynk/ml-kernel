# Mainline Synopsys DesignWare AXI DMA controller (drivers/dma/dw-axi-dmac) for the
# Artosyn axi_dma engine (artosyn,axi_dma @ 0x08800000, SPI 63/64/65, 3 channels).
#
# The block is a stock DW-axi-dmac. The DT node (dts/proxima-9311.dts,
# axidma@8800000) carries the mainline compatible "snps,axi-dma-1.01a" + the snps,*
# geometry the driver requires.
#
# Built IN (=y). DW_AXI_DMAC selects DMA_ENGINE + DMA_VIRTUAL_CHANNELS automatically;
# DMADEVICES is the menu gate (defconfig leaves it off) and DMA_OF is def_bool y under
# OF. trim.config does not touch any of these, but this fragment merges after it anyway.
CONFIG_DMADEVICES=y
CONFIG_DW_AXI_DMAC=y

# dmatest: modprobe dmatest then poke /sys/module/dmatest/parameters/{channel,run} to
# exercise a real channel memcpy on HW. Module so it is absent unless explicitly loaded.
# Pulls in DMA_ENGINE_RAID (harmless).
CONFIG_DMATEST=m
