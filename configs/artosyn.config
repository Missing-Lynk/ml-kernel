# Artosyn Proxima-9311 config fragment, merged onto `arm64 defconfig` by build.sh.
# Provides the platform base: UART console, /dev/mem for the closed media stack,
# CUSE/FUSE/binder, the USB gadget, SD, and the rootfs filesystems. Build a
# defconfig-only kernel with `MINIMAL=1 scripts/build.sh` to minimise variables.

# UART console (defconfig already has these; pinned explicitly)
CONFIG_SERIAL_8250=y
CONFIG_SERIAL_8250_CONSOLE=y
CONFIG_SERIAL_8250_DW=y
CONFIG_SERIAL_OF_PLATFORM=y
CONFIG_SERIAL_EARLYCON=y

# userspace: the closed media stack programs the codec from /dev/mem
# STRICT_DEVMEM must be OFF: ar_lowdelay mmaps the unclaimed media register space.
CONFIG_DEVMEM=y
# CONFIG_STRICT_DEVMEM is not set

# userspace: media "devices" are CUSE daemons over binder
CONFIG_FUSE_FS=y
CONFIG_CUSE=y
CONFIG_ANDROID_BINDER_IPC=y
CONFIG_ANDROID_BINDERFS=y

# USB gadget over dwc2 (SSH/ECM + RNDIS + ACM, the entry point we keep)
CONFIG_USB_GADGET=y
CONFIG_USB_DWC2=y
CONFIG_USB_LIBCOMPOSITE=y
CONFIG_USB_CONFIGFS=y
CONFIG_USB_CONFIGFS_ECM=y
CONFIG_USB_CONFIGFS_RNDIS=y
CONFIG_USB_CONFIGFS_ACM=y
CONFIG_USB_CONFIGFS_MASS_STORAGE=y

# SD card: Synopsys DesignWare MMC
CONFIG_MMC=y
CONFIG_MMC_DW=y

# rootfs: squashfs on ubiblock (vendor boots root=/dev/ubiblock0_0)
CONFIG_MTD=y
CONFIG_MTD_BLOCK=y
CONFIG_MTD_UBI=y
CONFIG_MTD_UBI_BLOCK=y
CONFIG_UBIFS_FS=y
CONFIG_SQUASHFS=y
CONFIG_SQUASHFS_XZ=y
CONFIG_SQUASHFS_LZ4=y

# SPI-NAND flash, so the kernel can reach the real rootfs
# Our custom `ar9301-qspi` controller driver is overlaid into drivers/spi/ by build.sh
# (patches/, built obj-y). Everything above it is mainline + built-in: the spi-mem
# core, the SPI-NAND subsystem (incl. the Xtx chip), and the partition parser. The rootfs
# partition map arrives as `mtdparts=spi32766.1:...` on the kernel cmdline.
CONFIG_SPI=y
CONFIG_SPI_MEM=y
CONFIG_MTD_SPI_NAND=y
CONFIG_MTD_NAND_CORE=y
CONFIG_MTD_CMDLINE_PARTS=y

# Expose the whole-flash device as mtd0, matching the stock kernel's partition numbering.
# The SPL Falcon boot rewrites the cmdline `ubi.mtd=` to <active-userapp GPT-ordinal + 6>
# = the STOCK mtd index (which assumes the master IS mtd0), so userapp1 must be mtd18 to
# match the SPL's `18`; without this option it's mtd17 and the SPL's value lands on
# usr_data instead -> rootfs mount fails.
CONFIG_MTD_PARTITIONED_MASTER=y

# The MMZ media carveout is a DT reserved-memory region (see dts/), no extra symbol.

# crash auto-recovery (a bad module load should reboot, not wedge)
# Software lockup/hung-task detectors so a module that spins or deadlocks (no oops) still
# panics -> reboot. Pair with rootfs /etc/sysctl.d/99-panic-reboot.conf (softlockup_panic=1,
# hung_task_panic=1, on top of the already-working panic_on_oops/panic/panic_on_rcu_stall).
CONFIG_SOFTLOCKUP_DETECTOR=y
CONFIG_DETECT_HUNG_TASK=y
