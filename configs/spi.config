# DesignWare SPI master (snps,dw-apb-ssi @ 0x1102000) + spidev, for the status LED (a
# WS2812-style RGB LED bit-banged over SPI from userspace). CONFIG_SPI=y already comes
# from artosyn.config (QSPI NAND); this adds the DesignWare controller + spidev access.
#
# MERGE AFTER trim.config. spidev still needs a DT spidev child node under the
# controller to expose /dev/spidev.

# Core symbol is SPI_DESIGNWARE (the DW SPI core); SPI_DW_MMIO/SPIDEV live under
# `if SPI_DESIGNWARE`, so the core must be =y for the glue to be =y.
CONFIG_SPI_DESIGNWARE=y
CONFIG_SPI_DW_MMIO=y
CONFIG_SPI_SPIDEV=y
