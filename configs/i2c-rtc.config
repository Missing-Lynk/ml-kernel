# I2C + RTC: DesignWare I2C controller (i2c0) with the board's battery-backable
# DS1307 RTC at 0x68. This is exactly the vendor's RTC path - the vendor kernel
# drives the DS1307 with the same mainline rtc-ds1307 driver and never binds a
# driver to the SoC-internal rtc@0a10c000 block (no such symbols in its kallsyms).
# CHARDEV gives /dev/i2c-0 for i2cdetect-style validation.
CONFIG_I2C=y
CONFIG_I2C_CHARDEV=y
CONFIG_I2C_DESIGNWARE_CORE=y
CONFIG_I2C_DESIGNWARE_PLATFORM=y
CONFIG_RTC_CLASS=y
CONFIG_RTC_INTF_SYSFS=y
CONFIG_RTC_INTF_PROC=y
CONFIG_RTC_INTF_DEV=y
# Set the system clock from the RTC at boot, like the vendor's rtc_hctosys.
CONFIG_RTC_HCTOSYS=y
CONFIG_RTC_HCTOSYS_DEVICE="rtc0"
CONFIG_RTC_DRV_DS1307=y
