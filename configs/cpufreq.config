# cpufreq/DVFS for the A53 cluster. cpufreq-dt binds the CPU nodes' clocks
# (<&pixclk 2> = cgu_cpu_clk in clk-ar9311-cgu.c) + the vendor OPP table in
# the DTS; cpufreq-dt-platdev auto-registers the platform device. Default
# governor = performance: exact vendor behavior (stock ships the same stack
# pinned to performance and never leaves 800 MHz). schedutil/userspace/powersave
# are also built, validated per-OPP with test_tools/cpufreq_test.sh.
CONFIG_PM=y
CONFIG_PM_OPP=y
CONFIG_CPU_FREQ=y
CONFIG_CPU_FREQ_STAT=y
CONFIG_CPU_FREQ_DEFAULT_GOV_PERFORMANCE=y
# CONFIG_CPU_FREQ_DEFAULT_GOV_SCHEDUTIL is not set
CONFIG_CPU_FREQ_GOV_PERFORMANCE=y
CONFIG_CPU_FREQ_GOV_POWERSAVE=y
CONFIG_CPU_FREQ_GOV_USERSPACE=y
CONFIG_CPU_FREQ_GOV_SCHEDUTIL=y
CONFIG_CPUFREQ_DT=y
CONFIG_CPUFREQ_DT_PLATDEV=y
