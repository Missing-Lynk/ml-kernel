# Front-panel buttons on the open kernel: the IIO SAR ADC provider (artosyn_adc.ko,
# modules/) + the in-kernel adc-keys voltage-ladder driver + evdev, which
# together produce /dev/input/event0 with the key codes the menu reads.
#
# MERGE THIS AFTER trim.config so it overrides trim's input/IIO disables.

# IIO core (industrialio) - artosyn_adc registers an IIO device against it.
CONFIG_IIO=y
# No IIO buffering: artosyn_adc uses INDIO_DIRECT_MODE one-shot reads and adc-keys polls,
# so the trigger/buffer infrastructure is dead weight.
# CONFIG_IIO_BUFFER is not set
# CONFIG_IIO_TRIGGERED_BUFFER is not set

# Input core + evdev + adc-keys, all built in (adc-keys depends on IIO, now =y).
CONFIG_INPUT=y
CONFIG_INPUT_EVDEV=y
CONFIG_INPUT_KEYBOARD=y
CONFIG_KEYBOARD_ADC=y
