# SD-card filesystem: exFAT, built in (the stock card ships exFAT, LABEL=SDCARD).
# Merged after trim.config, which drops FAT/VFAT.
#
# EXFAT_FS selects BUFFER_HEAD + LEGACY_DIRECT_IO + NLS; none of these can be =m,
# which is why exFAT cannot be delivered as an out-of-tree module against an
# already-flashed kernel (the flashed config compiled buffer_head out entirely).
#
# iocharset utf8 is handled natively by fs/exfat (no NLS table load at mount time).
CONFIG_EXFAT_FS=y
CONFIG_EXFAT_DEFAULT_IOCHARSET="utf8"
