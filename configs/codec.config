# Mainline Chips&Media Wave5 V4L2 driver for the Artosyn WAVE521C H.264/H.265
# engine (artosyn,h26x @ 0x0a080000, SPI 68).
#
# NOTE: trim.config sets `# CONFIG_MEDIA_SUPPORT is not set`; this fragment must be
# merged AFTER trim.config to win (registered after trim in container-build.sh).
#
# The in-tree wave5 driver is `depends on ARCH_K3 || COMPILE_TEST` and its of_match
# only lists "ti,j721s2-wave521c". The patched driver overlay in
# patches/drivers/media/platform/chips-media/wave5/ relaxes the Kconfig gate;
# the DT node binds it via that TI compatible (the Wave5 core is identical).
#
# The codec driver is a MODULE (=m). Building it in (=y) plus the embedded firmware
# pushed the Image over the 6 MiB kernel slot (101%), so it cannot flash. As a module,
# wave5.ko + firmware live on the rootfs and load AFTER the rootfs mounts, which also
# removes the firmware-timing problem that forced CONFIG_EXTRA_FIRMWARE. The media CORE
# stays built-in (=y) so wave5.ko has no module dependencies (single .ko to deploy).
# Staged to /lib/modules by modules/build.sh; firmware chagall.bin must be
# installed on the rootfs at /lib/firmware/cnm/wave521c_k3_codec_fw.bin (deploy step).

CONFIG_MEDIA_SUPPORT=y
CONFIG_MEDIA_PLATFORM_SUPPORT=y
CONFIG_V4L_MEM2MEM_DRIVERS=y
CONFIG_VIDEO_DEV=y
CONFIG_V4L2_MEM2MEM_DEV=y
CONFIG_VIDEOBUF2_CORE=y
CONFIG_VIDEOBUF2_V4L2=y
CONFIG_VIDEOBUF2_DMA_CONTIG=y
CONFIG_VIDEOBUF2_VMALLOC=y
CONFIG_GENERIC_ALLOCATOR=y
CONFIG_SRAM=y
CONFIG_VIDEO_WAVE_VPU=m

# The wave5 decoder allocates its DPB + display framebuffers from CMA (vb2-dma-contig).
# 720p needs ~24 buffers x ~1.35 MB, and the default 16 MiB fragments and fails
# ("cma: __cma_alloc ... ret: -16", "Framebuffer preparation, fail: -12"). Bump to 64 MiB.
# CMA is reusable (movable pages until DMA claims it), so it does not cost system RAM idle.
# For reference, the vendor firmware's media carveout is 108 MiB @ 0x29400000; concurrent
# 1080p decode plus encode needs a budget on that order.
# 56 MiB: holds the ml-pipeline composite pool (~42 MiB) with margin, while leaving the wave5 codec
# its own MMZ carveout (DTS mmz node) and ~92 MiB general System RAM. The composite MUST be CMA (mmap-able
# dma-buf needs struct pages; MMZ is no-map) - see docs/reference/memory-map.md.
CONFIG_CMA_SIZE_MBYTES=56
