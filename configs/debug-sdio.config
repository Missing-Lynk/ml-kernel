# SDIO/MMC bring-up debug fragment (opt-in via DEBUGSDIO=1, slot-B only).
#
# Enables runtime dynamic_debug for dw_mmc + mmc_core, so an SDIO/MMC scan can be traced
# live instead of guessing from the outcome alone:
#
#   mount -t debugfs none /sys/kernel/debug   # if not already
#   echo 'module dw_mmc_core +p'  > /sys/kernel/debug/dynamic_debug/control
#   echo 'module mmc_core +p'     > /sys/kernel/debug/dynamic_debug/control
#   # then trigger a scan and read dmesg for the CMD sequence, responses, and error codes
#
# NB: DYNAMIC_DEBUG enlarges the kernel (the __dyndbg table + the format strings the trim
# pass otherwise drops). The slot-B kernel is size-trimmed to fit the 6 MiB kernel slot; a
# build with this fragment may need to relax a trim or confirm the dtb/kernel partition has
# room. This is a throwaway diagnostic image, not the shipping one.

CONFIG_DEBUG_FS=y
CONFIG_DYNAMIC_DEBUG_CORE=y
CONFIG_DYNAMIC_DEBUG=y
CONFIG_MMC_DEBUG=y
