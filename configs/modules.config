# Kernel config required by the out-of-tree modules (modules/) and the
# self-describing-kernel guarantee.
#
# MERGE AFTER trim.config so these options win over trim.config's disables (trim
# sets `# CONFIG_FB`/`# CONFIG_MMC is not set`). container-build.sh handles the
# ordering; if you build by hand, keep this fragment after trim.config in the
# merge_config.sh fragment list.

# Self-describing kernel
# Lets us build modules against the EXACT running config (zcat /proc/config.gz),
# avoiding a stackprotector/ABI mismatch between a module and a differently-
# configured kernel tree.
CONFIG_IKCONFIG=y
CONFIG_IKCONFIG_PROC=y

# Symbol-versioning: OFF by design (see modules/KERNEL-REQUIREMENTS.md). With
# MODVERSIONS on, every module load is gated on a per-symbol CRC that must come
# from the EXACT same kernel build - which only holds if kernel Image, modules,
# and the rootfs that carries them are all cut from one tree AND kernel1+rootfs are
# flashed in lockstep. In practice they drift (e.g. rootfs staged 01:06 modules
# next to a 12:08 kernel), and the CRC mismatch is not "an obvious insmod error"
# but a silent ENOEXEC on every module -> no display/PWM/SDIO drivers -> black
# screen + dead RF, with nothing in dmesg. Off, the loader checks only vermagic
# (which matches across configs), so a build skew degrades gracefully instead of
# bricking the boot. Keep it off.
# CONFIG_MODVERSIONS is not set

# fbdev core + /dev/fbN device nodes: backs the DRM fbdev emulation
# (display.config sets DRM_FBDEV_EMULATION=y), which puts the boot console on
# the panel. The DRM path renders via the sysmem helpers its Kconfig selects;
# the CFB (I/O-mem) blit helpers were only needed by the removed ar_framebuffer.
CONFIG_FB=y
CONFIG_FB_DEVICE=y

# artosyn_sdio + dw_mci-artosyn: MMC/SDIO core
# Provides sdio_register_driver/__sdio_register_driver, sdio_readb/writeb,
# sdio_memcpy_toio, sdio_claim_host/release_host, sdio_enable_func, sdio_claim_irq,
# sdio_f0_readb/writeb, mmc_wait_for_cmd. The host-controller side (DesignWare,
# DT node `mmc1` non-removable + cap-sdio-irq) is the out-of-tree dw_mci-artosyn
# glue in modules/, not this fragment.
CONFIG_MMC=y
CONFIG_MMC_DW=y
