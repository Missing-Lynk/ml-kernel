# Kernel config required by the out-of-tree modules (modules/) and the
# self-describing-kernel guarantee.
#
# MERGE AFTER trim.config so these options win over trim.config's disables (trim
# sets `# CONFIG_FB`/`# CONFIG_MMC is not set`). container-build.sh handles the
# ordering; if you build by hand, keep this fragment after trim.config in the
# merge_config.sh fragment list.

# Self-describing kernel
# Lets us build modules against the EXACT running config (zcat /proc/config.gz),
# avoiding a stackprotector/ABI mismatch between a module and a differently-
# configured kernel tree.
CONFIG_IKCONFIG=y
CONFIG_IKCONFIG_PROC=y

# Symbol-versioning: stamp each exported symbol with a CRC of its prototype so a
# module built against a mismatched kernel is rejected cleanly at insmod
# ("disagrees about version of symbol ...") instead of loading and then silently
# corrupting / panicking. Our modules always build against the exact tree
# (build.sh runs modules_prepare + `make modules` on $KTREE), so the CRCs match by
# construction - this just turns an ABI drift into an obvious error.
CONFIG_MODVERSIONS=y

# fbdev core + /dev/fbN device nodes + cfb blit helpers: backs the DRM fbdev
# emulation (display.config sets DRM_FBDEV_EMULATION=y), which puts the boot
# console on the panel.
CONFIG_FB=y
CONFIG_FB_DEVICE=y
CONFIG_FB_CFB_FILLRECT=y
CONFIG_FB_CFB_COPYAREA=y
CONFIG_FB_CFB_IMAGEBLIT=y

# artosyn_sdio + dw_mci-artosyn: MMC/SDIO core
# Provides sdio_register_driver/__sdio_register_driver, sdio_readb/writeb,
# sdio_memcpy_toio, sdio_claim_host/release_host, sdio_enable_func, sdio_claim_irq,
# sdio_f0_readb/writeb, mmc_wait_for_cmd. The host-controller side (DesignWare,
# DT node `mmc1` non-removable + cap-sdio-irq) is the out-of-tree dw_mci-artosyn
# glue in modules/, not this fragment.
CONFIG_MMC=y
CONFIG_MMC_DW=y
