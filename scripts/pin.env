# Pinned inputs for the reproducible modern-kernel build. Bump deliberately.
# Verified by sha256 in build.sh; that plus fixed build metadata + the hermetic
# container makes the resulting Image bit-reproducible.

KERNEL_VERSION=6.18.36
KERNEL_URL=https://cdn.kernel.org/pub/linux/kernel/v6.x/linux-6.18.36.tar.xz
KERNEL_SHA256=fbab86c9f471c81075b280cca30bd85d790c060063a1245859b6344b07c9c44e

# Default location of the (large) kernel build tree, shared by build.sh, modules/build.sh,
# and rootfs/build.sh (they must agree). Override with BUILD_DIR=. Defaults to build/ inside
# the repo (gitignored via the root .gitignore `build/` rule), so a fresh checkout just builds
# with no path to know and everything stays under the project dir. The build is hermetic
# (container), so this path never affects the Image hash.
_ML_REPO="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
KERNEL_BUILD_DEFAULT="$_ML_REPO/build/kernel-repro-${KERNEL_VERSION}"

# kernel.org canonical cross toolchain (x86_64 host -> aarch64), gcc 14.2.0
TOOLCHAIN_VERSION=14.2.0
TOOLCHAIN_URL=https://mirrors.edge.kernel.org/pub/tools/crosstool/files/bin/x86_64/14.2.0/x86_64-gcc-14.2.0-nolibc-aarch64-linux.tar.xz
TOOLCHAIN_SHA256=53deb48c660f1453ca79fa224d44de1145c8c5377d90040934af063d1b726b29
CROSS_COMPILE_PREFIX=aarch64-linux-

# Deterministic build metadata (fixed -> reproducible banner/timestamps).
# 2024-11-01T00:00:00Z; arbitrary but fixed.
SOURCE_DATE_EPOCH=1730419200
KBUILD_BUILD_USER=brushlesswhoop
KBUILD_BUILD_HOST=repro

# Container tag (built from scripts/Dockerfile; pinned debian base inside it).
BUILD_IMAGE=ml-kbuild:6.7
