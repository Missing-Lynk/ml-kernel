Why: the codec allocates from a fixed dedicated pool, and upstream gives no
visibility into its consumption - exhaustion surfaces only as a downstream
V4L2 error with no indication of what filled the pool. Adds a running
per-allocation tally (dev_info on alloc/free, dev_warn with the tally on
ENOMEM).

--- a/drivers/media/platform/chips-media/wave5/wave5-vdi.c
+++ b/drivers/media/platform/chips-media/wave5/wave5-vdi.c
@@ -115,6 +115,20 @@
 	return len;
 }
 
+/*
+ * Artosyn: running tally of codec-pool demand. The per-device coherent pool is
+ * page-granular first-fit (kernel/dma/coherent.c, downstream), so each allocation
+ * costs PAGE_ALIGN(size); the tally makes pool pressure visible before ENOMEM.
+ * NOTE: only covers wave5_vdi allocations; vb2 CAPTURE/OUTPUT buffers (dma-contig
+ * against the same pool) are not counted here.
+ */
+static atomic64_t ml_pool_used = ATOMIC64_INIT(0);
+
+static size_t ml_pool_rounded(size_t size)
+{
+	return PAGE_ALIGN(size);
+}
+
 int wave5_vdi_allocate_dma_memory(struct vpu_device *vpu_dev, struct vpu_buf *vb)
 {
 	void *vaddr;
@@ -126,8 +140,17 @@
 	}
 
 	vaddr = dma_alloc_coherent(vpu_dev->dev, vb->size, &daddr, GFP_KERNEL);
-	if (!vaddr)
+	if (!vaddr) {
+		dev_warn(vpu_dev->dev,
+			 "%s: ENOMEM for %zu B (rounded %zu); vdi pool tally %lld B\n",
+			 __func__, vb->size, ml_pool_rounded(vb->size),
+			 (long long)atomic64_read(&ml_pool_used));
 		return -ENOMEM;
+	}
+	atomic64_add(ml_pool_rounded(vb->size), &ml_pool_used);
+	dev_info(vpu_dev->dev, "%s: +%zu B (rounded %zu), vdi pool tally %lld B\n",
+		 __func__, vb->size, ml_pool_rounded(vb->size),
+		 (long long)atomic64_read(&ml_pool_used));
 	vb->vaddr = vaddr;
 	vb->daddr = daddr;
 
@@ -139,10 +162,12 @@
 	if (vb->size == 0)
 		return -EINVAL;
 
-	if (!vb->vaddr)
+	if (!vb->vaddr) {
 		dev_err(vpu_dev->dev, "%s: requested free of unmapped buffer\n", __func__);
-	else
+	} else {
 		dma_free_coherent(vpu_dev->dev, vb->size, vb->vaddr, vb->daddr);
+		atomic64_sub(ml_pool_rounded(vb->size), &ml_pool_used);
+	}
 
 	memset(vb, 0, sizeof(*vb));
 
