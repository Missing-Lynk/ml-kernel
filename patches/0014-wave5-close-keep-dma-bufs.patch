-	for (i = 0; i < inst->fbc_buf_count; i++)
-		wave5_vpu_dec_reset_framebuffer(inst, i);
+	/* ML (Artosyn): when close left the firmware instance running (keep_dma_bufs),
+	 * the framebuffers and bitstream ring are still firmware DMA targets; freeing
+	 * them lets the firmware write reallocated memory and hard-hangs the SoC.
+	 * Leak them, matching the work/task buffers the close path already leaked. */
+	if (inst->keep_dma_bufs) {
+		dev_warn(inst->dev->dev,
+			 "instance not quiesced, leaking framebuffers and bitstream ring\n");
+	} else {
+		for (i = 0; i < inst->fbc_buf_count; i++)
+			wave5_vpu_dec_reset_framebuffer(inst, i);
 
-	wave5_vdi_free_dma_memory(inst->dev, &inst->bitstream_vbuf);
+		wave5_vdi_free_dma_memory(inst->dev, &inst->bitstream_vbuf);
