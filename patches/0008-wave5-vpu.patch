 #include <linux/clk.h>
 #include <linux/firmware.h>
 #include <linux/interrupt.h>
 #include <linux/pm_runtime.h>
 #include <linux/reset.h>
+#include <linux/io.h>
+#include <linux/delay.h>
+#include <linux/bits.h>
