+	/*
+	 * Artosyn Proxima-9311: power on the h26x/WAVE521C codec before touching any
+	 * VPU register. Without this the whole host interface reads back 0 (product
+	 * code 0x0) and probe fails at wave5_vdi_init. The mainline binding has no
+	 * clock/PMU/reset provider for this SoC's media CRG + power controller, so
+	 * program it raw here (sequence recovered from the vendor libmpp_service
+	 * ar_video_h26x_clock_on + ar_video_h26x_power_on). Must run on the cold
+	 * boot-time probe so the VCPU is initialised from a clean reset.
+	 * Media CRG page @0x0a106000, power-isolation page @0x0a102000.
+	 * TODO: model these as proper clock/power-domain controllers in DT and drop this.
+	 */
+	{
+		void __iomem *crg = ioremap(0x0a106000, 0x1000);
+		void __iomem *iso = ioremap(0x0a102000, 0x1000);
+
+		if (crg && iso) {
+			int i;
+
+			/* 1. media clock gate: 0x0a106008 = (v & 0xffffe000) | BIT(13) */
+			writel((readl(crg + 0x008) & 0xffffe000) | BIT(13), crg + 0x008);
+			/* 2. PMU unlock key */
+			writel(0x00acce55, crg + 0x200);
+			/* 3. venc power-up request: bits 6, 14, 22 */
+			writel(readl(crg + 0x204) | 0x00404040, crg + 0x204);
+			/* 4. poll power-up ack on 0x0a106208 bits 6 & 14 */
+			for (i = 0; i < 1000; i++) {
+				if ((readl(crg + 0x208) & 0x4040) == 0x4040)
+					break;
+				udelay(10);
+			}
+			if (i == 1000)
+				dev_warn(&pdev->dev, "venc power-up ack timeout (0x%08x)\n",
+					 readl(crg + 0x208));
+			/* 5. clear the power-up REQUEST pulse (bit 22) now it's acked */
+			writel(readl(crg + 0x204) & ~0x00400000, crg + 0x204);
+			/* 6. de-isolate the venc power domain */
+			writel(readl(iso + 0x004) | BIT(26), iso + 0x004);
+			writel(readl(iso + 0x014) | BIT(2), iso + 0x014);
+			/* 7. venc clock gate (belt-and-braces; usually already set): 0x0a106018 BIT(12) */
+			writel(readl(crg + 0x018) | BIT(12), crg + 0x018);
+			usleep_range(1000, 2000); /* let the domain + clock settle */
+		} else {
+			dev_warn(&pdev->dev, "could not map media CRG/PMU to power on the codec\n");
+		}
