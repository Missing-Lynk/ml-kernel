 		return 0;
 
 	/*
+	 * ML (Artosyn WAVE521C): same mainline TODO as the decode path above - the
+	 * rdo/lf size calc is unimplemented, so the sizes stay 0 and this enables
+	 * sec-AXI RDO+LF (BIT(11)|BIT(15)) into the tiny 64 KiB SRAM with bogus
+	 * (zero) size accounting. That exact pattern corrupted decode write-back
+	 * until forced to 0 (vendor writes USE_SEC_AXI=0). No sec-AXI on WAVE521C.
+	 */
+	if (inst->dev->product_code != WAVE515_CODE)
+		return 0;
+
+	/*
 	 * TODO: calculate rdo_size and lf_size from inst->src_fmt.width and
 	 * inst->codec_info->enc_info.open_param.wave_param.internal_bit_depth
 	 */
