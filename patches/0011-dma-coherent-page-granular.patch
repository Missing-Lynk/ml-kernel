+/* ML (Artosyn): debugfs introspection for per-device coherent pools. The pool
+ * shared by the wave5 codec and the ml_mmzheap dma-heap was a black box (only
+ * indirect tenant-side tallies existed); this prints base/size, used/free page
+ * counts, the largest free run, and the live allocation list, all under the
+ * pool spinlock so the walk is a consistent snapshot.
+ */
+static int dma_coherent_debugfs_show(struct seq_file *s, void *unused)
+{
+	struct dma_coherent_mem *mem = s->private;
+	unsigned long flags;
+	unsigned long pos = 0;
+	unsigned long used = 0;
+	unsigned long best_run = 0;
+	unsigned long allocs = 0;
+
+	spin_lock_irqsave(&mem->spinlock, flags);
+	seq_printf(s, "base: %pad\n", &mem->device_base);
+	seq_printf(s, "pages: %d (%d KiB)\n", mem->size,
+		   mem->size << (PAGE_SHIFT - 10));
+	while (pos < mem->size) {
+		if (!test_bit(pos, mem->bitmap)) {
+			unsigned long next = find_next_bit(mem->bitmap,
+							   mem->size, pos);
+
+			if (next - pos > best_run)
+				best_run = next - pos;
+			pos = next;
+			continue;
+		}
+		if (mem->nr_map[pos]) {
+			seq_printf(s, "alloc: page %lu +%u\n", pos,
+				   mem->nr_map[pos]);
+			used += mem->nr_map[pos];
+			allocs++;
+			pos += mem->nr_map[pos];
+		} else {
+			/* set bit without an allocation start: interior of a
+			 * runaway record, should not happen */
+			seq_printf(s, "orphan bit: page %lu\n", pos);
+			used++;
+			pos++;
+		}
+	}
+	seq_printf(s, "allocs: %lu\n", allocs);
+	seq_printf(s, "used: %lu pages (%lu KiB)\n", used,
+		   used << (PAGE_SHIFT - 10));
+	seq_printf(s, "free: %lu pages (%lu KiB)\n", mem->size - used,
+		   (mem->size - used) << (PAGE_SHIFT - 10));
+	seq_printf(s, "largest free run: %lu pages (%lu KiB)\n", best_run,
+		   best_run << (PAGE_SHIFT - 10));
+	spin_unlock_irqrestore(&mem->spinlock, flags);
+	return 0;
+}
+DEFINE_SHOW_ATTRIBUTE(dma_coherent_debugfs);
+
+static void dma_coherent_debugfs_add(struct dma_coherent_mem *mem,
+				     const char *name)
+{
+	static DEFINE_MUTEX(dir_lock);
+	static struct dentry *dir;
+
+	if (mem->debugfs)
+		return;
+	mutex_lock(&dir_lock);
+	if (!dir)
+		dir = debugfs_create_dir("dma_coherent", NULL);
+	mutex_unlock(&dir_lock);
+	mem->debugfs = debugfs_create_file(name, 0400, dir, mem,
+					   &dma_coherent_debugfs_fops);
+}
